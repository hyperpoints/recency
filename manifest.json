{
	"manifest_version": 3,
	"name": "Tab Recency",
	"version": "1.4",
	"permissions": ["tabs", "tabGroups", "storage"],
	"background": {
		"scripts": ["background.js"]
	},
	"action": {
		"default_title": "Tab Recency",
		"default_popup": "popup.html"
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "move-tab-top@yourname.dev"
		}
	}
}
